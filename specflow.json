{
  "$schema": "https://specflow.org/specflow-config.json",
  "language": {
    "feature": "en-US"
  },
  "bindingCulture": {
    "name": "en-US"
  },
  "generator": {
    "allowDebugGeneratedFiles": false
  },
  "runtime": {
    "missingOrPendingStepsOutcome": "Inconclusive",
    "stopAtFirstError": false
  }
}